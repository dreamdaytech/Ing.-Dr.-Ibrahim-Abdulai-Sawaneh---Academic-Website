rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Secure catch-all: by default, deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // publications collection: anyone can read, only authenticated users can write
    match /publications/{pubId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // books collection: anyone can read, only authenticated users can write
    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // blogPosts collection: anyone can read, only authenticated users can write
    match /blogPosts/{blogId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // talkEvents collection: anyone can read, only authenticated users can write
    match /talkEvents/{talkId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // timelineItems collection: anyone can read, only authenticated users can write
    match /timelineItems/{timelineId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // profile collection: anyone can read, only authenticated users can write
    match /profile/{profileId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
